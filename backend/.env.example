OPTILOAD_APP_NAME=OptiLoad Backend
OPTILOAD_ENVIRONMENT=development
OPTILOAD_API_PREFIX=/api/v1
OPTILOAD_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/optiload
OPTILOAD_JWT_SECRET_KEY=replace_with_a_long_random_secret_min_32_chars
OPTILOAD_JWT_ALGORITHM=HS256
OPTILOAD_JWT_ACCESS_TOKEN_MINUTES=30
OPTILOAD_RATE_LIMIT_PER_MINUTE=60
OPTILOAD_CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
OPTILOAD_TRUSTED_HOSTS=["localhost","127.0.0.1"]
