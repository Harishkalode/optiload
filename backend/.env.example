OPTILOAD_APP_NAME=OptiLoad Backend
OPTILOAD_ENVIRONMENT=development
OPTILOAD_API_PREFIX=/api/v1
OPTILOAD_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/optiload
OPTILOAD_JWT_SECRET_KEY=replace_with_a_long_random_secret_min_32_chars
OPTILOAD_JWT_ALGORITHM=HS256
OPTILOAD_JWT_ACCESS_TOKEN_MINUTES=15
OPTILOAD_JWT_REFRESH_TOKEN_DAYS=7
OPTILOAD_JWT_ISSUER=optiload
OPTILOAD_JWT_AUDIENCE=optiload-clients
OPTILOAD_RATE_LIMIT_PER_MINUTE=60
OPTILOAD_AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
# memory (default) or redis — requires: pip install redis>=5
OPTILOAD_RATE_LIMIT_BACKEND=memory
OPTILOAD_REDIS_URL=
OPTILOAD_REDIS_RATE_LIMIT_KEY_PREFIX=optiload:rl
OPTILOAD_MAX_REQUEST_BODY_BYTES=1048576
OPTILOAD_CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
OPTILOAD_TRUSTED_HOSTS=["localhost","127.0.0.1"]
# Local: true. Production: set false unless you intentionally allow open signup.
OPTILOAD_ALLOW_PUBLIC_REGISTRATION=true
# Bootstrap first super_admin only when explicitly enabled; use strong password from a secret manager.
OPTILOAD_BOOTSTRAP_SUPER_ADMIN_ENABLED=false
OPTILOAD_BOOTSTRAP_SUPER_ADMIN_EMAIL=
OPTILOAD_BOOTSTRAP_SUPER_ADMIN_PASSWORD=
OPTILOAD_BOOTSTRAP_SUPER_ADMIN_NAME=Platform Admin
