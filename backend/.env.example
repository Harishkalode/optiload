# ═══════════════════════════════════════════════════════════
# OptiLoad Environment Configuration
# ═══════════════════════════════════════════════════════════
# Change OPTILOAD_ENVIRONMENT to switch between local/test/production
# All security and scalability settings auto-configure based on environment
# ═══════════════════════════════════════════════════════════

# ─── CORE (REQUIRED) ──────────────────────────────────────
OPTILOAD_ENVIRONMENT=local

# ─── DATABASE (REQUIRED) ──────────────────────────────────
OPTILOAD_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/optiload
# OPTILOAD_DATABASE_READ_URL=

# ─── AUTH (REQUIRED) ──────────────────────────────────────
OPTILOAD_JWT_SECRET_KEY=change-this-to-a-unique-32-plus-character-secret

# ─── CORS (REQUIRED) ──────────────────────────────────────
OPTILOAD_CORS_ALLOWED_ORIGINS='["http://localhost:5173"]'
OPTILOAD_TRUSTED_HOSTS='["localhost","127.0.0.1"]'

# ─── REDIS (Required for production) ──────────────────────
# OPTILOAD_REDIS_URL=redis://localhost:6379/0

# ─── MONITORING ───────────────────────────────────────────
# OPTILOAD_SENTRY_DSN=

# ─── SECURITY OVERRIDES (Optional - auto-set by environment) ──
# OPTILOAD_CSRF_ENABLED=true
# OPTILOAD_ACCOUNT_LOCKOUT_ENABLED=true
# OPTILOAD_ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
# OPTILOAD_ACCOUNT_LOCKOUT_DURATION_MINUTES=15
# OPTILOAD_MFA_REQUIRED_FOR_ROLES='["super_admin","admin"]'
# OPTILOAD_MAX_REQUEST_BODY_BYTES=524288

# ─── RATE LIMITING (Optional - auto-set by environment) ──
# OPTILOAD_RATE_LIMIT_PER_MINUTE=60
# OPTILOAD_AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=5
# OPTILOAD_RATE_LIMIT_BACKEND=redis

# ─── PERFORMANCE (Optional - auto-set by environment) ────
# OPTILOAD_DB_POOL_SIZE=20
# OPTILOAD_DB_MAX_OVERFLOW=40
# OPTILOAD_DB_STATEMENT_TIMEOUT_MS=30000
# OPTILOAD_CACHE_ENABLED=true
# OPTILOAD_CACHE_DEFAULT_TTL=300

# ─── LOGGING (Optional - auto-set by environment) ────────
# OPTILOAD_LOG_LEVEL=WARNING
# OPTILOAD_STRUCTURED_LOGGING=true
# OPTILOAD_ACCESS_LOG_ENABLED=false

# ─── API DOCS (Optional - auto-set by environment) ───────
# OPTILOAD_ENABLE_API_DOCS=false

# ─── REGISTRATION (Optional - auto-set by environment) ───
# OPTILOAD_ALLOW_PUBLIC_REGISTRATION=false

# ─── BOOTSTRAP (Optional) ────────────────────────────────
# OPTILOAD_BOOTSTRAP_SUPER_ADMIN_ENABLED=false
# OPTILOAD_BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
# OPTILOAD_BOOTSTRAP_SUPER_ADMIN_PASSWORD=SecureP@ssw0rd!
