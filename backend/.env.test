OPTILOAD_ENVIRONMENT=testing
OPTILOAD_DATABASE_URL=postgresql+psycopg2://optiload:optiload@localhost:5432/optiload_test
OPTILOAD_JWT_SECRET_KEY=test-secret-key-for-ci-pipeline-only-32chars
OPTILOAD_CORS_ALLOWED_ORIGINS='["http://localhost:5173"]'
OPTILOAD_TRUSTED_HOSTS='["localhost","127.0.0.1"]'
OPTILOAD_ALLOW_PUBLIC_REGISTRATION=true
OPTILOAD_RATE_LIMIT_BACKEND=memory
OPTILOAD_RATE_LIMIT_PER_MINUTE=1000
OPTILOAD_AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=1000
OPTILOAD_DB_POOL_SIZE=5
OPTILOAD_DB_MAX_OVERFLOW=10
